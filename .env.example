# =====================================================================
# Opticks Audio — Environment configuration
# =====================================================================
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local` to git.
#
# Where to get each value is documented in DEPLOY.md.
# =====================================================================

# ----- Public site URL ------------------------------------------------
# Used in transactional emails (confirmation links, unsubscribe links)
# and as the canonical base for redirects. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://opticksaudio.com

# ----- Supabase (public values) --------------------------------------
# Found in Supabase dashboard → Settings → API Keys.
# Supabase rebranded these in 2025; "publishable" === "anon".
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Supabase (server-only secrets) --------------------------------
# Found in Supabase dashboard → Settings → API Keys → Secret keys.
# Supabase rebranded "service_role" → "secret". Same powers.
# THIS BYPASSES ROW LEVEL SECURITY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Resend (email delivery) ---------------------------------------
# Found at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@opticksaudio.com
RESEND_FROM_NAME=Opticks Audio

# ----- Waitlist signing secret ---------------------------------------
# Used to HMAC-sign tamper-proof unsubscribe links.
# Generate with:  openssl rand -hex 32
WAITLIST_SECRET=replace-with-output-of-openssl-rand-hex-32
